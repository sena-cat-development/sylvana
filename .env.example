# Configuración para Generador de Actas con Gemini AI
GEMINI_API_KEY=tu_api_key_de_gemini_aqui
MODELO_GEMINI=gemini-3.1-flash-lite-preview


# Metadatos institucionales
INSTITUCION=SENA
CENTRO=Centro Agroturístico
REGION=Santander
COORDINADOR_ACADEMICO=NOMBRE_DEL_COORDINADOR_ACADEMICO
BIENESTAR_APRENDIZ=NOMBRE_DEL_BIENESTAR_APRENDIZ

# Configuración de archivos
DIRECTORIO_ACTAS=.actas_gemini
GUARDAR_VERSIONES=true
NUMERO_VERSIONES=2

# Configuración adicional para mejor extracción
MODO_DETALLADO=true

# Configuración Hugging Face
HF_TOKEN=tu_token_de_huggingface_aqui

# Modelo Whisper — auto-detectado según VRAM
# Opciones: auto, tiny, base, small, medium, large-v3
# auto selecciona según VRAM: <4GB→base, 4-8GB→small, 8-16GB→medium, >16GB→large-v3
# WHISPER_MODEL=auto

# Timeout de transcripción en minutos (default: 180 = 3 horas)
# Para audios largos (2+ horas) con GPU débil, puede necesitar más tiempo
# TRANSCRIPTION_TIMEOUT=180

# Configuración GPU — auto-detectada según hardware
# Descomenta solo si necesitás forzar un valor específico
# CUDA_VISIBLE_DEVICES=0   # Forzar GPU índice 0 (útil en servidores con múltiples GPUs)
# DEVICE=cuda              # Forzar 'cuda' o 'cpu' (auto: detecta GPU compatible)
# BATCH_SIZE=4             # Forzar lote (auto: 1 en CPU, 2-16 según VRAM disponible)
# COMPUTE_TYPE=float16     # Forzar precisión (auto: int8 en CPU, float16 en GPU ≥ Volta)
QUIET_MODE=false
